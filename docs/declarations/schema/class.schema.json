{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClassDefinition",
  "type": "object",
  "required": [
    "name",
    "version",
    "kind",
    "required_headers",
    "payload_schema",
    "standing_rules",
    "relation_rules"
  ],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "kind": { "type": "string" },
    "required_headers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "payload_schema": { "type": "string" },
    "standing_rules": { "type": "object" },
    "relation_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relation_type", "counterparty_classes"],
        "properties": {
          "relation_type": { "type": "string" },
          "counterparty_classes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "direction": {
            "type": "string",
            "enum": ["outgoing", "incoming", "bidirectional"]
          },
          "authorizing_endpoint": {
            "type": "string",
            "enum": ["source", "target", "either_endpoint"]
          }
        }
      }
    },
    "validators": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
